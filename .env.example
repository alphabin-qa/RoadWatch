# --- AI backend (Python/FastAPI) ---
# Base URL of the FastAPI backend that serves /api/chat and /api/identify-road.
# Leave empty to use the in-app Next.js routes (Gemini) instead.
NEXT_PUBLIC_AI_BACKEND_URL=http://localhost:8000

# --- Gemini (only used if NEXT_PUBLIC_AI_BACKEND_URL is empty) ---
GEMINI_API_KEY=

# --- Supabase (live mode) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
