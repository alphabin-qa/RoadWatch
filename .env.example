# --- AI backend (Python/FastAPI) ---
# Base URL of the FastAPI backend that serves /api/chat and /api/identify-road.
# Leave empty to use the in-app Next.js routes (Gemini) instead.
NEXT_PUBLIC_AI_BACKEND_URL=http://localhost:8000

# --- Gemini (only used if NEXT_PUBLIC_AI_BACKEND_URL is empty) ---
GEMINI_API_KEY=

# --- Supabase (live mode) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (authentication) ---
# From the Clerk dashboard → API keys. Required: every route except
# /sign-in and /sign-up is protected by middleware.ts.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
